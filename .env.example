# ============================================================================
# Ancestry Research Automation - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values
# Required fields are marked with [REQUIRED]
# Optional fields have sensible defaults
# ============================================================================

# ============================================================================
# ANCESTRY AUTHENTICATION [REQUIRED]
# ============================================================================
ANCESTRY_USERNAME=your_email@example.com  # [REQUIRED]
ANCESTRY_PASSWORD=your_password  # [REQUIRED]

# ============================================================================
# AI PROVIDER CONFIGURATION [REQUIRED - Choose at least one]
# ============================================================================
# Options: gemini, deepseek, local_llm, moonshot, grok, inception, tetrate
AI_PROVIDER=gemini  # [REQUIRED]

# AI Provider Fallbacks (comma-separated, used when primary fails)
# Example: AI_PROVIDER_FALLBACKS=deepseek,local_llm
AI_PROVIDER_FALLBACKS=

# --- Google Gemini ---
GOOGLE_API_KEY=  # [REQUIRED if AI_PROVIDER=gemini]
GOOGLE_AI_MODEL=gemini-1.5-flash-latest
# GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com

# --- DeepSeek ---
DEEPSEEK_API_KEY=  # [REQUIRED if AI_PROVIDER=deepseek]
DEEPSEEK_AI_MODEL=deepseek-chat
# DEEPSEEK_AI_BASE_URL=https://api.deepseek.com

# --- Moonshot (Kimi) ---
MOONSHOT_API_KEY=  # [REQUIRED if AI_PROVIDER=moonshot]
MOONSHOT_AI_MODEL=kimi-k2-thinking
# MOONSHOT_AI_BASE_URL=https://api.moonshot.ai/v1

# --- Grok (xAI) ---
XAI_API_KEY=  # [REQUIRED if AI_PROVIDER=grok]
XAI_MODEL=grok-4-fast-non-reasoning
# XAI_API_HOST=api.x.ai

# --- Tetrate (TARS) ---
TARS_API_KEY=  # [REQUIRED if AI_PROVIDER=tetrate]
TETRATE_AI_MODEL=xai/grok-code-fast-1
# TETRATE_AI_BASE_URL=https://api.router.tetrate.ai/v1

# --- Inception Mercury ---
INCEPTION_API_KEY=  # [REQUIRED if AI_PROVIDER=inception]
INCEPTION_AI_MODEL=mercury
# INCEPTION_AI_BASE_URL=https://api.inceptionlabs.ai/v1

# --- Local LLM (LM Studio) ---
LOCAL_LLM_API_KEY=lm-studio
LOCAL_LLM_MODEL=qwen2.5-14b-instruct
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LM_STUDIO_PATH=C:\\Program Files\\LM Studio\\LM Studio.exe
LM_STUDIO_AUTO_START=true
LM_STUDIO_STARTUP_TIMEOUT=60

# ============================================================================
# RATE LIMITING [CRITICAL - Do not change without validation]
# ============================================================================
# Requests per second (validated safe rate for Ancestry API)
REQUESTS_PER_SECOND=2.0

# Maximum rate limiter will allow (ceiling)
RATE_LIMITER_MAX_RATE=20.0

# Target throughput for match processing (1.0 = steady pace)
TARGET_MATCH_THROUGHPUT=1.0

# Maximum concurrency (1 = sequential, safest for API)
MAX_CONCURRENCY=1

# ============================================================================
# DATABASE & GEDCOM [Optional - Sensible defaults]
# ============================================================================
# Database file location
DATABASE_FILE=Data/ancestry.db

# GEDCOM family tree file
GEDCOM_FILE_PATH=Data/family_tree.ged

# Database connection pool size
DB_POOL_SIZE=10

# SQLite journal mode (WAL recommended for performance)
DB_JOURNAL_MODE=WAL

# ============================================================================
# CHROME/SELENIUM [Optional - Auto-detect usually works]
# ============================================================================
# CHROME_DRIVER_PATH=
# CHROME_BROWSER_PATH=
# CHROME_USER_DATA_DIR=
# PROFILE_DIR=Default

# Headless mode (set to true for servers without display)
HEADLESS_MODE=false

# ============================================================================
# APPLICATION SETTINGS [Optional]
# ============================================================================
# Environment: development, testing, production
ENVIRONMENT=development

# Application display name
APP_NAME=Ancestry Research Automation

# App mode: development, production (controls safety features)
APP_MODE=development

# Debug mode (enables verbose logging)
DEBUG_MODE=false

# Skip slow API tests during development
SKIP_LIVE_API_TESTS=true
SKIP_SLOW_TESTS=false

# Test execution gates
RUN_MODULE_TESTS=0
RUN_INTERNAL_TESTS=0
ANCESTRY_TEST_MODE=mock

# ============================================================================
# USER PERSONALIZATION [Optional - Used in message templates]
# ============================================================================
# Your name (appears in messages)
USER_NAME=

# Your location (appears in messages)
USER_LOCATION=

# Reference person in tree (UUID or ID)
REFERENCE_PERSON_ID=
REFERENCE_PERSON_NAME=

# ============================================================================
# MICROSOFT TO-DO INTEGRATION [Optional]
# ============================================================================
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT_ID=consumers
MS_TODO_LIST_NAME=Genealogy Research

# ============================================================================
# MONITORING & OBSERVABILITY [Optional]
# ============================================================================
# Grafana dashboard settings
GRAFANA_BASE_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
# GRAFANA_API_TOKEN=

# Prometheus metrics
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_METRICS_ENABLED=false
PROMETHEUS_METRICS_HOST=0.0.0.0
PROMETHEUS_METRICS_PORT=9001
PROMETHEUS_METRICS_NAMESPACE=ancestry
PROMETHEUS_AUTO_START=false
# PROMETHEUS_BINARY_PATH=

# Prometheus test requirements
PROM_REQUIRE_SAMPLES=true
PROM_REQUIRE_TARGET=true
PROM_REQUIRE_AVAILABLE=true
PROM_SCRAPE_ATTEMPTS=8
PROM_SCRAPE_DELAY_SECONDS=5

# ============================================================================
# LOGGING [Optional - Sensible defaults]
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=Logs/app.log
MAX_LOG_SIZE_MB=10

# ============================================================================
# CACHING [Optional - Sensible defaults]
# ============================================================================
CACHE_DIR=Cache
MEMORY_CACHE_SIZE=1000
DISK_CACHE_SIZE_MB=100

# ============================================================================
# TESTING [Optional - For test fixtures]
# ============================================================================
TEST_PROFILE_ID=
TEST_UUID=
TEST_USERNAME=
TEST_PERSON_FIRST_NAME=Fraser
TEST_PERSON_LAST_NAME=Gault
TEST_PERSON_BIRTH_YEAR=1941
TEST_PERSON_BIRTH_PLACE=Banff
TEST_PERSON_GENDER=M
TEST_PERSON_EXPECTED_SCORE=200
TEST_PERSON_EXPECTED_API_SCORE=200

# ============================================================================
# FEATURE FLAGS [Optional - Advanced]
# ============================================================================
# FEATURE_FLAGS_FILE=

# DNA match probability threshold (cM)
DNA_MATCH_PROBABILITY_THRESHOLD_CM=10

# Phase 5 feature toggles
PHASE5_ENABLE_SOURCE_CITATIONS=true
PHASE5_ENABLE_RELATIONSHIP_DIAGRAMS=true
PHASE5_ENABLE_RESEARCH_SUGGESTIONS=false

# ============================================================================
# QUALITY CHECKS [Optional - CI/CD]
# ============================================================================
# QUALITY_CHECK_FILES=
# QUALITY_CHECK_THRESHOLD=

# ============================================================================
# ADVANCED [Optional - Rarely changed]
# ============================================================================
# Action 6 checkpoint file
ACTION6_CHECKPOINT_FILE=Cache/action6_checkpoint.json

# Checkpoint settings
ENABLE_CHECKPOINTING=true
CHECKPOINT_MAX_AGE_HOURS=24

# Thread pool workers for DNA gathering (1 = safest)
THREAD_POOL_WORKERS=1

# Max pages to process (0 = unlimited)
MAX_PAGES=0

# My Ancestry profile ID (used for statistics and routing)
MY_PROFILE_ID=

# Flask secret key for web UI sessions
FLASK_SECRET_KEY=

# Security settings
ENCRYPTION_ENABLED=false
USE_SYSTEM_KEYRING=false
SESSION_TIMEOUT_MINUTES=60

# Chrome debug port
DEBUG_PORT=9222

# API endpoint throttle profiles (JSON format)
# API_ENDPOINT_THROTTLES={"Ethnicity Comparison API":{"min_interval":0.1,"max_rate":2.0}}

# Prometheus test settings
PROM_REQUIRE_SAMPLES=true
PROM_REQUIRE_TARGET=true
PROM_REQUIRE_AVAILABLE=true
PROM_SCRAPE_ATTEMPTS=8
PROM_SCRAPE_DELAY_SECONDS=5
PROM_FAKE_METRICS_URL=http://localhost:9001/metrics

# Config skip dotenv (for testing)
CONFIG_SKIP_DOTENV=

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit .env file to version control (it's in .gitignore)
# 2. Keep API keys secure - rotate regularly
# 3. REQUESTS_PER_SECOND is critical - validate before changing
# 4. Test configuration with Action 5 (Check Login) before heavy use
# 5. For Docker deployment, ensure all required vars are set
# ============================================================================
